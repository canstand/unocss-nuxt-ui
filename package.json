{
  "name": "unocss-nuxt-ui",
  "type": "module",
  "version": "1.0.2",
  "packageManager": "pnpm@10.32.1",
  "description": "Use UnoCSS with Nuxt UI without Tailwind CSS",
  "license": "MIT",
  "homepage": "https://github.com/canstand/unocss-nuxt-ui#readme",
  "repository": "canstand/unocss-nuxt-ui",
  "bugs": {
    "url": "https://github.com/canstand/unocss-nuxt-ui/issues"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt-ui",
    "unocss",
    "unocss-preset",
    "tailwindcss",
    "tailwind-replacement",
    "atomic-css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./preset": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && changelogen --release && pnpm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@nuxt/ui": ">=4.0.0",
    "@unocss/nuxt": ">=0.66.0",
    "nuxt": ">=3.10.0",
    "unocss": ">=0.66.0"
  },
  "dependencies": {
    "@nuxt/kit": "catalog:",
    "@unocss/core": "catalog:",
    "@unocss/preset-wind4": "catalog:",
    "defu": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@iconify-json/lucide": "catalog:",
    "@nuxt/devtools": "catalog:",
    "@nuxt/eslint-config": "catalog:",
    "@nuxt/module-builder": "catalog:",
    "@nuxt/schema": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@nuxt/ui": "catalog:",
    "@types/node": "catalog:",
    "@unhead/vue": "catalog:",
    "@unocss/eslint-plugin": "catalog:",
    "changelogen": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "lint-staged": "catalog:",
    "nuxt": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "unocss": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
